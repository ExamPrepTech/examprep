# ── Server ─────────────────────────────────────────────
PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/examprep
JWT_SECRET=change-me
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5001/api
ADMIN_EMAIL=ganeshknsml@gmail.com

# ── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP ───────────────────────────────────────
# Required to send password-reset emails. If unset, dev logs the reset link instead.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Leave unset to auto-derive (true on 465, false otherwise), or force true/false.
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="ExamPrep Support" <noreply@examprep.com>
